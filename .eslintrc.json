{
	"extends": ["airbnb", "prettier", "plugin:react/jsx-runtime"],
	"plugins": ["prettier"],
	"ignorePatterns": ["build"],
	"rules": {
		"prettier/prettier": ["error"],
		"react/jsx-indent": ["error", "tab"],
		"react/jsx-indent-props": ["error", "tab"],
		"react/function-component-definition": [
			2,
			{ "namedComponents": "arrow-function" }
		]
	},
	"env": {
		"browser": true,
		"es2023": true,
		"node": false
	},
	"parserOptions": {
		"ecmaVersion": "latest",
		"sourceType": "module"
	},
	"settings": {
		"import/resolver": {
			"node": {
				"paths": ["src"]
			}
		}
	},
	"overrides": [
		{
			"files": [
				"src/**/*.test.js",
				"src/**/*.test.jsx",
				"src/setupTests.js",
				"src/test/**/*.js",
				"src/test/**/*.jsx"
			],
			"env": {
				"node": true,
				"browser": true
			},
			"rules": {
				"no-undef": "off",
				"import/no-extraneous-dependencies": [
					"error",
					{
						"devDependencies": true
					}
				]
			}
		},
		{
			"files": ["vite.config.js"],
			"env": {
				"node": true,
				"browser": false
			},
			"rules": {
				"import/no-extraneous-dependencies": [
					"error",
					{
						"devDependencies": true
					}
				]
			}
		}
	]
}
